<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused/Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#1A9C7D14" /> <!-- Light gold ripple -->
                    <stroke android:width="2dp" android:color="@color/gold_primary_dark" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:gravity="end|center_vertical" android:right="12dp">
                <vector android:width="24dp" android:height="24dp" android:viewportWidth="24" android:viewportHeight="24">
                    <path android:fillColor="@color/gold_primary_dark" android:pathData="M7,10l5,5 5,-5z" />
                </vector>
            </item>
        </layer-list>
    </item>
    <!-- Normal state -->
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/white" />
                    <stroke android:width="1dp" android:color="@color/text_secondary" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:gravity="end|center_vertical" android:right="12dp">
                <vector android:width="24dp" android:height="24dp" android:viewportWidth="24" android:viewportHeight="24">
                    <path android:fillColor="@color/text_secondary" android:pathData="M7,10l5,5 5,-5z" />
                </vector>
            </item>
        </layer-list>
    </item>
</selector>