<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.GoldZakatCalculator" parent="Theme.Material3.DayNight">
        <!-- Primary brand color (Gold) -->
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryDark">@color/gold_primary_dark</item>
        <item name="colorOnPrimary">@color/gold_on_primary</item>
        <item name="colorPrimaryContainer">@color/gold_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/gold_on_primary</item>

        <!-- Secondary / accent color (Green) -->
        <item name="colorSecondary">@color/green_accent</item>
        <item name="colorOnSecondary">@color/green_on_accent</item>
        <item name="colorSecondaryContainer">@color/green_accent_light</item>
        <item name="colorOnSecondaryContainer">@color/green_accent_dark</item>

        <!-- Status bar matches primary gold -->
        <item name="android:statusBarColor">@color/gold_primary_dark</item>
        <item name="android:navigationBarColor">@color/cream_background</item>

        <!-- Background / surface -->
        <item name="android:windowBackground">@color/cream_background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error color -->
        <item name="colorError">@color/error_red</item>

        <!-- ActionBar -->
        <item name="actionBarStyle">@style/Widget.GoldZakat.ActionBar</item>
    </style>

    <style name="Widget.GoldZakat.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">@color/gold_primary</item>
        <item name="titleTextStyle">@style/TextAppearance.GoldZakat.ActionBarTitle</item>
    </style>

    <style name="TextAppearance.GoldZakat.ActionBarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/gold_on_primary</item>
    </style>

    <!-- Card style used in layouts -->
    <style name="GoldZakat.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Button style -->
    <style name="GoldZakat.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/green_accent</item>
        <item name="android:textColor">@color/green_on_accent</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="GoldZakat.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gold_primary_dark</item>
        <item name="hintTextColor">@color/gold_primary_dark</item>
    </style>

</resources>
